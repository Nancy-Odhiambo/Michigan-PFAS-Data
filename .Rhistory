#| label: sites_bubble
# Static PFAS sites map
pfas_sites_sf <- pfas_sites %>%
mutate(
type = str_replace_all(type, "mlitary", "military"),
type = str_to_title(type),
type = str_replace_all(type, "Laundromat/Drycleaner", "Laundromat/Dry Cleaner"),
type = case_when(
type %in% c("Tannery", "Unknown", "Refinery", "Laundromat/Dry Cleaner", "Paper Manufacturing", "Fire Station") ~ "Other",
TRUE ~ type
)
) %>%
st_as_sf(coords = c("longitude", "latitude"), crs = 4326)
pfas_static_map2 <- ggplot() +
geom_sf(data = mi_counties,
fill = "white",
color = "black",
linewidth = 0.3) +
geom_sf(data = pfas_sites_sf,
aes(fill = type),
size = 5,
pch = 21,
alpha = 0.7,
color = "black") +
scale_fill_manual(values = c(
"Landfill"     = "#E69F00",
"Industrial"   = "#56B4E9",
"Other"        = "#CC79A7",
"Plating"      = "#F0E442",
"Wastewater"   = "#0072B2",
"Airport"      = "#999999",
"Military"     = "#009E73",
"Fire Related" = "#D55E00"
)) +
labs(fill = "Site Type") +
coord_sf(
xlim = c(mi_bbox["xmin"], mi_bbox["xmax"]),
ylim = c(mi_bbox["ymin"], mi_bbox["ymax"]),
expand = FALSE
) +
theme_map(base_size = 32) +
theme(
legend.position = c(0.02, 0.1),
legend.justification = c("left", "bottom"),
legend.key.size = unit(1.2, "cm"),
legend.spacing.x = unit(0.4, "cm"),
plot.margin = ggplot2::margin(0, 0, 0, 0),
text = element_text(family = "Arial")
)
ggsave("pfas_sites_map2.svg", pfas_static_map2, width = 15, height = 18)

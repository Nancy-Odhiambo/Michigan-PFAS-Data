mutate(
scaled_radius = sqrt(Hazard_Index / max(Hazard_Index, na.rm = TRUE)) * max_radius,
size_plot = scaled_radius / max(scaled_radius) * 10
)
# Bubble legend data
legend_data <- tibble(
Hazard_Index = seq(5, max_val, by = 5)
) %>%
mutate(
scaled_radius = sqrt(Hazard_Index / max_val) * max_radius,
size_plot = scaled_radius / max(scaled_radius) * 10
)
# bubble legend
bubble_legend <- ggplot(legend_data) +
geom_point(
aes(x = 0, y = Hazard_Index, size = size_plot, fill = Hazard_Index),
shape = 21,
color = "black",
alpha = 0.9,
stroke = 0.4
) +
geom_text(
aes(x = 0.6, y = Hazard_Index, label = Hazard_Index),
hjust = 0,
size = 7,
fontface = "bold",
color = "black"
) +
scale_size_identity() +
scale_fill_distiller(
palette = "YlOrRd",
direction = 1,
guide = "none"   # ← THIS prevents ggplot from creating a fill legend
) +
coord_fixed() +
theme_void() +
theme(
plot.background = element_rect(fill = "gray95", color = NA),
plot.margin = unit(c(10, 10, 10, 10), "pt")
) +
xlim(-0.5, 2)
# Hazard map without legends
map_plot <- ggplot() +
geom_sf(data = mi_counties,
fill = "white",
color = "black",
linewidth = 0.3) +
geom_sf(data = hazard_sites_full,
aes(size = size_plot, fill = Hazard_Index),
shape = 21,
color = "black",
alpha = 0.85,
stroke = 0.3) +
scale_fill_distiller(palette = "YlOrRd", direction = 1, guide = "none") +
scale_size_identity(guide = "none") +
labs(
title = "Hazard Index by Water System (Michigan)"
) +
theme_map(base_size = 22) +
theme(
plot.title = element_text(face = "bold", color = "black"),
plot.background = element_rect(fill = "gray95", color = NA)
)
# Combine hazard map + bubble legend
combined_map <- map_plot + bubble_legend +
patchwork::plot_layout(widths = c(4, 1))
ggsave("hazard_map.png", combined_map, width = 16, height = 10, dpi = 300)
# System-level hazard decomposition
system_analytes <- public_water_max_long |>
filter(
Hazard_Index > 1,
!is.na(analyte),
analyte %in% hazard_analytes,
!is.na(analyte_value),
!is.na(system_name)
) |>
mutate(
system_name = tolower(system_name),
analyte_hazard = case_when(
analyte == "HFPODA" ~ analyte_value / 10,
analyte == "PFNA"   ~ analyte_value / 10,
analyte == "PFBS"   ~ analyte_value / 2000,
analyte == "PFHxS"  ~ analyte_value / 10
)
) |>
group_by(system_name, analyte) |>
summarise(
total_hazard_analyte = sum(analyte_hazard, na.rm = TRUE),
.groups = "drop"
)
system_total <- system_analytes |>
group_by(system_name) |>
summarise(
total_hazard = sum(total_hazard_analyte, na.rm = TRUE),
.groups = "drop"
) |>
arrange(desc(total_hazard)) |>
slice_head(n = 10)
system_analytes_top <- system_analytes |>
filter(system_name %in% system_total$system_name) |>
mutate(system_name = factor(system_name, levels = system_total$system_name))
# Horizontal stacked bar chart for top systems
p_system_hazard <- ggplot(
system_analytes_top,
aes(y = system_name,
x = total_hazard_analyte,
fill = analyte)
) +
geom_col(width = 0.7) +
scale_fill_manual(values = hazard_colors) +
labs(
title = "Hazard Index Decomposition for Top Systems",
x = "Hazard Index",
y = "System Name",
fill = "Analyte"
) +
theme(
legend.position = "bottom"
)
ggsave("system_hazard.png", p_system_hazard, width = 14, height = 10, dpi = 300)
# Static PFAS sites map
pfas_sites_sf <- pfas_sites %>%
mutate(
type = str_replace_all(type, "mlitary", "military"),
type = str_to_title(type),
type = str_replace_all(type, "Laundromat/Drycleaner", "Laundromat/Dry Cleaner"),
type = case_when(
type %in% c("Tannery", "Unknown", "Refinery", "Fire Station") ~ "Other",
TRUE ~ type
)
) %>%
st_as_sf(coords = c("longitude", "latitude"), crs = 4326)
site_types <- sort(unique(pfas_sites_sf$type))
pfas_pal <- colorRampPalette(RColorBrewer::brewer.pal(9, "YlOrRd"))(length(site_types))
names(pfas_pal) <- site_types
pfas_static_map <- ggplot() +
geom_sf(data = mi_counties,
fill = "white",
color = "black",
linewidth = 0.3) +
geom_sf(data = pfas_sites_sf,
aes(color = type),
size = 3,
alpha = 0.9) +
scale_color_manual(values = pfas_pal) +
labs(
title = "PFAS Contamination Sites in Michigan",
color = "Site Type"
) +
theme_map(base_size = 22) +
theme(
plot.title = element_text(face = "bold", color = "black"),
legend.position = "right",
legend.title = element_text(face = "bold", color = "black"),
legend.text = element_text(face = "bold", color = "black"),
plot.background = element_rect(fill = "gray95", color = NA),
panel.background = element_rect(fill = "gray95", color = NA)
)
ggsave("pfas_sites_map.png", pfas_static_map, width = 14, height = 10, dpi = 300)
# Build metrics table from system_locations
metrics_table <- system_locations |>
group_by(system_short) |>
summarise(
n_systems = n(),
mean_hazard = mean(Hazard_Index, na.rm = TRUE),
total_hazard = sum(Hazard_Index, na.rm = TRUE),
dominant_analyte = first(dominant_analyte),
dominant_hazard = first(dominant_hazard),
.groups = "drop"
) |>
left_join(
system_type_map %>% select(short_name, full_name),
by = c("system_short" = "short_name")
) |>
arrange(desc(n_systems)) |>
mutate(
mean_hazard = round(mean_hazard, 2),
total_hazard = round(total_hazard, 2),
dominant_hazard = round(dominant_hazard, 2)
)
# Build poster-ready static table
gt_metrics <- metrics_table |>
gt() |>
tab_header(
title = md("**System Metrics Summary**")
) |>
cols_label(
full_name = "Full Descriptive Name",
system_short = "Short Name",
n_systems = "Number of Systems",
mean_hazard = "Mean Hazard Index",
total_hazard = "Total Hazard Index",
dominant_analyte = "Dominant Analyte",
dominant_hazard = "Dominant Analyte Contribution"
) |>
tab_options(
table.background.color = "gray80",
heading.background.color = "gray80",
column_labels.background.color = "gray80",
table.font.size = 20,
data_row.padding = px(8),
heading.align = "center",
column_labels.border.top.color = "black",
column_labels.border.bottom.color = "black",
table.border.top.color = "black",
table.border.bottom.color = "black"
) |>
tab_style(
style = cell_text(weight = "bold", color = "black"),
locations = cells_column_labels(everything())
) |>
tab_style(
style = cell_text(color = "black"),
locations = cells_body()
)
# Save as PNG
gtsave(gt_metrics, "system_metrics_table.png", expand = 10)
# Define main hazard analytes and colors
hazard_analytes <- c("HFPODA", "PFNA", "PFBS", "PFHxS")
hazard_colors <- c(
"HFPODA" = "#332288",
"PFNA"   = "#117733",
"PFBS"   = "#44AA99",
"PFHxS"  = "#88CCEE"
)
# Global theme for all plots
theme_set(
theme_classic(base_size = 22) +
theme(
plot.title = element_text(face = "bold", color = "black"),
axis.title = element_text(face = "bold", color = "black"),
axis.text = element_text(face = "bold", color = "black"),
legend.title = element_text(face = "bold", color = "black"),
legend.text = element_text(face = "bold", color = "black"),
plot.background = element_rect(fill = "gray95", color = NA),
panel.background = element_rect(fill = "gray95", color = NA)
)
)
# Aggregate analyte-level hazard contributions
total_analyte_hazard <- public_water_max_long |>
filter(analyte %in% hazard_analytes) |>
mutate(analyte_hazard = case_when(
analyte == "HFPODA" ~ analyte_value / 10,
analyte == "PFNA"   ~ analyte_value / 10,
analyte == "PFBS"   ~ analyte_value / 2000,
analyte == "PFHxS"  ~ analyte_value / 10
)) |>
group_by(analyte) |>
summarise(
total_contribution = sum(analyte_hazard, na.rm = TRUE),
.groups = "drop"
) |>
arrange(desc(total_contribution)) |>
mutate(
percent = round(total_contribution / sum(total_contribution) * 100, 1),
analyte = factor(analyte, levels = analyte)
)
# Bar chart for analytes
p_bar <- ggplot(total_analyte_hazard,
aes(x = analyte, y = total_contribution, fill = analyte)) +
geom_col(width = 0.7) +
geom_text(aes(label = paste0(percent, "%")),
vjust = -0.5, size = 7, fontface = "bold") +
scale_fill_manual(values = hazard_colors) +
labs(
title = "Decomposed Hazard Index Contributions by Analyte",
x = "Analyte",
y = "Total Hazard Index Contribution"
) +
ylim(0, max(total_analyte_hazard$total_contribution) * 1.15)
ggsave("analyte_contributions.png", p_bar, width = 12, height = 8, dpi = 300)
# Load Michigan counties
mi_counties <- st_read("GeoFiles/cb_2018_us_county_500k.shp", quiet = TRUE) %>%
filter(STATEFP == "26") %>%
st_transform(4326)
# Prepare analyte-wide data for hazard sites
analyte_wide <- public_water_max_long %>%
filter(analyte %in% hazard_analytes) %>%
select(hex_id, analyte, analyte_value) %>%
pivot_wider(
names_from = analyte,
values_from = analyte_value,
values_fill = 0
)
# Prepare hazard sites
hazard_sites_full <- public_water_max_long %>%
filter(Hazard_Index > 1) %>%
distinct(hex_id, system_name, system_type, Hazard_Index, longitude, latitude) %>%
rename(type = system_type) %>%
left_join(analyte_wide, by = "hex_id") %>%
st_as_sf(coords = c("longitude", "latitude"), crs = 4326) %>%
mutate(
Hazard_Index = as.numeric(Hazard_Index),
system_name = tolower(system_name),
type = tolower(type)
)
# Scale hazard values for bubbles
max_radius <- 20
desired_max <- max(hazard_sites_full$Hazard_Index, na.rm = TRUE)
max_val <- ceiling(desired_max / 5) * 5
hazard_sites_full <- hazard_sites_full %>%
mutate(
scaled_radius = sqrt(Hazard_Index / max(Hazard_Index, na.rm = TRUE)) * max_radius,
size_plot = scaled_radius / max(scaled_radius) * 10
)
# Bubble legend data
legend_data <- tibble(
Hazard_Index = seq(5, max_val, by = 5)
) %>%
mutate(
scaled_radius = sqrt(Hazard_Index / max_val) * max_radius,
size_plot = scaled_radius / max(scaled_radius) * 10
)
# bubble legend
bubble_legend <- ggplot(legend_data) +
geom_point(
aes(x = 0, y = Hazard_Index, size = size_plot, fill = Hazard_Index),
shape = 21,
color = "black",
alpha = 0.9,
stroke = 0.4
) +
geom_text(
aes(x = 0.6, y = Hazard_Index, label = Hazard_Index),
hjust = 0,
size = 7,
fontface = "bold",
color = "black"
) +
scale_size_identity() +
scale_fill_distiller(
palette = "YlOrRd",
direction = 1,
guide = "none"   # ← THIS prevents ggplot from creating a fill legend
) +
coord_fixed() +
theme_void() +
theme(
plot.background = element_rect(fill = "gray95", color = NA),
plot.margin = unit(c(10, 10, 10, 10), "pt")
) +
xlim(-0.5, 2)
# Hazard map without legends
map_plot <- ggplot() +
geom_sf(data = mi_counties,
fill = "white",
color = "black",
linewidth = 0.3) +
geom_sf(data = hazard_sites_full,

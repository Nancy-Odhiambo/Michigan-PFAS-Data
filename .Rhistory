#| label: hazard map
# Prepare analyte-wide data for hazard sites
analyte_wide <- public_water_max_long %>%
filter(analyte %in% hazard_analytes) %>%
select(hex_id, analyte, analyte_value) %>%
pivot_wider(
names_from = analyte,
values_from = analyte_value,
values_fill = 0
)
# Prepare hazard sites
hazard_sites_full <- public_water_max_long %>%
filter(Hazard_Index > 1) %>%
distinct(hex_id, system_name, system_type, Hazard_Index, longitude, latitude) %>%
rename(type = system_type) %>%
left_join(analyte_wide, by = "hex_id") %>%
st_as_sf(coords = c("longitude", "latitude"), crs = 4326) %>%
mutate(
Hazard_Index = as.numeric(Hazard_Index),
system_name = tolower(system_name),
type = tolower(type)
)
# Hazard_map
map_plot2 <- ggplot() +
geom_sf(data = mi_counties,
fill = "white", color = "black", linewidth = 0.3) +
geom_sf(data = hazard_sites_full,
aes(size = Hazard_Index, fill = Hazard_Index),
shape = 21, color = "black", stroke = 0.4,
alpha = 0.8) +
scale_fill_distiller(name = "Hazard Index", palette = "YlOrRd",
direction = 1, trans = "log1p",
breaks = breaks_log(n = 6)) +
scale_size_continuous(name = "Hazard Index", trans = "log1p",
breaks = breaks_log(n = 6),
range = c(4, 18)) +
coord_sf(
xlim = c(mi_bbox["xmin"], mi_bbox["xmax"]),
ylim = c(mi_bbox["ymin"], mi_bbox["ymax"] - 0.05 * (mi_bbox["ymax"] - mi_bbox["ymin"])),
expand = FALSE
) +
guides(fill = guide_legend(),
size = guide_legend()) +
theme_map(base_size = 32) +
theme(
legend.position = c(0.02, 0.1),

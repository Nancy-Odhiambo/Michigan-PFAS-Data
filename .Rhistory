p_system_hazard <- ggplot(
system_analytes_top,
aes(y = system_name,
x = total_hazard_analyte,
fill = analyte)
) +
geom_col(width = 0.7) +
scale_fill_manual(values = hazard_colors) +
labs(
title = "Hazard Index Decomposition for Top Systems",
x = "Hazard Index",
y = "System Name",
fill = "Analyte"
) +
theme(
legend.position = "bottom"
)
ggsave("system_hazard.svg", p_system_hazard, width = 14, height = 10)
width=1479&height=779p_system_hazard
p_system_hazard
#| label: hazard analyte by system_name
# System-level hazard decomposition
system_analytes <- public_water_max_long |>
filter(
Hazard_Index > 1,
!is.na(analyte),
analyte %in% hazard_analytes,
!is.na(analyte_value),
!is.na(system_name)
) |>
mutate(
system_name = tolower(system_name),
analyte_hazard = case_when(
analyte == "HFPODA" ~ analyte_value / 10,
analyte == "PFNA"   ~ analyte_value / 10,
analyte == "PFBS"   ~ analyte_value / 2000,
analyte == "PFHxS"  ~ analyte_value / 10
)
) |>
group_by(system_name, analyte) |>
summarise(
total_hazard_analyte = sum(analyte_hazard, na.rm = TRUE),
.groups = "drop"
)
system_total <- system_analytes |>
group_by(system_name) |>
summarise(
total_hazard = sum(total_hazard_analyte, na.rm = TRUE),
.groups = "drop"
) |>
arrange(desc(total_hazard)) |>
slice_head(n = 10)
system_analytes_top <- system_analytes |>
filter(system_name %in% system_total$system_name) |>
mutate(system_name = factor(system_name, levels = system_total$system_name))
# Horizontal stacked bar chart for top systems
p_system_hazard <- ggplot(
system_analytes_top,
aes(y = system_name,
x = total_hazard_analyte,
fill = analyte)
) +
geom_col(width = 0.7) +
scale_fill_manual(values = hazard_colors) +
scale_y_continuous(expand = expansion(mult = c(0, 0.1))) +
labs(
title = "Hazard Index Decomposition for Top Systems",
x = "Hazard Index",
y = "System Name",
fill = "Analyte"
) +
theme(
legend.position = "bottom"
)
ggsave("system_hazard.svg", p_system_hazard, width = 14, height = 10)
